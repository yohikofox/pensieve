# ===========================================
# Pensine — Deploy Configuration
# ===========================================
# Copy this file to deploy.env and fill in your values.
# deploy.env is git-ignored — never commit secrets.

# -------------------------------------------
# Docker Registry
# -------------------------------------------
REGISTRY=cregistry.yolo.yt

# Version tag — defaults to short git SHA if not set
# VERSION=v1.0.0

# Target platform for Docker builds
PLATFORM=linux/amd64

# -------------------------------------------
# Next.js Build Args (web & admin)
# -------------------------------------------
NEXT_PUBLIC_API_URL=https://api.pensine.pro

# -------------------------------------------
# Portainer CE API
#
# PORTAINER_URL      → base URL of your Portainer instance
# PORTAINER_TOKEN    → API key (Settings → API Keys → Add API key)
# PORTAINER_STACK_ID → numeric stack ID (find in Portainer URL or via API)
# PORTAINER_INSECURE → set to "true" if using a self-signed TLS certificate
#
# The deploy script will:
#   1. Fetch current stack env vars
#   2. Update BACKEND_VERSION, WEB_VERSION, ADMIN_VERSION to the new git SHA
#   3. PUT /api/stacks/{id} with pullImage=true to pull & restart containers
# -------------------------------------------
PORTAINER_URL=https://docker.yolo.yt
PORTAINER_TOKEN=ptr_REPLACE_ME
PORTAINER_STACK_ID=44
PORTAINER_INSECURE=false

# -------------------------------------------
# MinIO — APK Upload (mobile build)
# -------------------------------------------
MINIO_ENDPOINT=http://minio.homelab.local:9000
MINIO_ACCESS_KEY=YOUR_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_SECRET_KEY
MINIO_BUCKET=pensine-apks
